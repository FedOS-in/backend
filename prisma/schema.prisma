generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FormFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  CHECKBOX
  RADIO
  BOOLEAN
  FILE
  EMAIL
  PHONE
  TEXTAREA
}

enum PaymentPeriod {
  PRE_APPROVAL
  POST_APPROVAL
}

model FederationNode {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isActive  Boolean  @default(true) @map("is_active")
  isDelete  Boolean  @default(false) @map("is_delete")

  parent   FederationNode?  @relation("FederationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children FederationNode[] @relation("FederationHierarchy")

  forms           FederationForm[]
  users           FederationUser[]
  membershipTypes MembershipType[]

  @@index([parentId])
  @@map("federation_nodes")
}

model CurrencyType {
  id   Int    @id @default(autoincrement())
  name String @unique

  membershipTypes MembershipType[]

  @@map("currency_types")
}

model Validity {
  id    Int    @id @default(autoincrement())
  label String
  days  Int?

  membershipTypes MembershipType[]

  @@map("validities")
}

model MembershipType {
  id               String   @id @default(uuid()) @db.Uuid
  label            String
  description      String?
  federationNodeId String   @map("federation_node_id") @db.Uuid
  code             String
  currencyId       Int      @map("currency_id")
  validityId       Int      @map("validity_id")
  joiningFee       Decimal  @map("joining_fee") @db.Decimal(12, 2)
  renewalFee       Decimal  @map("renewal_fee") @db.Decimal(12, 2)
  /// 1 = Active, 0 = Inactive
  status           Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_on") @db.Timestamptz(6)

  federationNode FederationNode @relation(fields: [federationNodeId], references: [id], onDelete: Restrict)
  currency       CurrencyType   @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  validity       Validity       @relation(fields: [validityId], references: [id], onDelete: Restrict)
  forms          FederationForm[]
  users          FederationUser[]

  @@unique([federationNodeId, code])
  @@index([federationNodeId])
  @@index([currencyId])
  @@index([validityId])
  @@map("membership_types")
}

model MembershipPeriod {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("membership_periods")
}

model FederationForm {
  id               String         @id @default(uuid()) @db.Uuid
  federationNodeId String         @map("federation_node_id") @db.Uuid
  name             String
  version          Int            @default(1)
  isActive         Boolean        @default(true) @map("is_active")
  paymentPeriod    PaymentPeriod? @map("payment_period")
  membershipTypeId String?        @map("membership_type_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  federationNode FederationNode  @relation(fields: [federationNodeId], references: [id], onDelete: Cascade)
  membershipType MembershipType? @relation(fields: [membershipTypeId], references: [id], onDelete: Restrict)
  fields         FormField[]
  users          FederationUser[]

  @@index([federationNodeId])
  @@index([membershipTypeId])
  @@unique([federationNodeId, name, version])
  @@map("federation_forms")
}

model FormField {
  id         String        @id @default(uuid()) @db.Uuid
  formId     String        @map("form_id") @db.Uuid
  fieldKey   String        @map("field_key")
  label      String
  fieldType  FormFieldType @map("field_type")
  isRequired Boolean       @default(false) @map("is_required")
  sortOrder  Int           @default(0) @map("sort_order")
  options    Json?
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  form FederationForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@unique([formId, fieldKey])
  @@map("form_fields")
}

model ApprovalStatus {
  id    Int    @id @default(autoincrement())
  name  String
  value Int    @unique

  users FederationUser[]

  @@map("approval_statuses")
}

model PaymentStatus {
  id   Int    @id @default(autoincrement())
  name String @unique

  users FederationUser[]

  @@map("payment_statuses")
}

model FederationUser {
  id               String   @id @default(uuid()) @db.Uuid
  federationNodeId String   @map("federation_node_id") @db.Uuid
  formId           String   @map("form_id") @db.Uuid
  membershipTypeId String?  @map("membership_type_id") @db.Uuid
  /// Format: {MembershipType.code}-{year}-{sequence}, e.g. AAA-2026-001
  memberId         String?  @unique @map("member_id")

  name        String
  email       String
  phoneNumber String  @map("phone_number")
  addressLine1 String  @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String
  state        String
  pincode      String
  passwordHash String  @map("password_hash")
  approvalStatus Int   @default(1) @map("approval_status")
  paymentStatus  Int   @default(1) @map("payment_status")

  dynamicFields Json    @default("{}") @map("dynamic_fields")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  federationNode FederationNode  @relation(fields: [federationNodeId], references: [id], onDelete: Restrict)
  form           FederationForm  @relation(fields: [formId], references: [id], onDelete: Restrict)
  membershipType MembershipType? @relation(fields: [membershipTypeId], references: [id], onDelete: Restrict)
  status         ApprovalStatus @relation(fields: [approvalStatus], references: [value], onDelete: Restrict)
  payment        PaymentStatus  @relation(fields: [paymentStatus], references: [id], onDelete: Restrict)

  @@index([federationNodeId])
  @@index([formId])
  @@index([membershipTypeId])
  @@index([email])
  @@index([phoneNumber])
  @@index([paymentStatus])
  @@map("federation_users")
}